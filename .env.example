FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
JWT_SECRET_KEY=change-me-to-another-long-random-string-at-least-32-chars

# SQLite by default; use postgresql://user:pass@host:5432/dbname for production
DATABASE_URL=sqlite:///elevator_chip.db

# Seeded admin account (created on first startup if missing)
ADMIN_PHONE=+995591000001
ADMIN_PASSWORD=ChangeMeAdmin123!
ADMIN_ID_NUMBER=01011000001

# Default region when phone numbers are entered without a country code (Georgia)
DEFAULT_PHONE_REGION=GE

# JWT token lifetime in seconds (default 1 hour)
JWT_ACCESS_TOKEN_EXPIRES=3600

# Rate limiting storage (memory:// for dev; redis://localhost:6379 for production)
RATELIMIT_STORAGE_URI=memory://

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
